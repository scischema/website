{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Polymerase Chain Reaction (PCR) Process Schema",
  "description": "Comprehensive schema for PCR processes including standard endpoint PCR, real-time qPCR, RT-qPCR, single-cell PCR, PCR-ASO, and droplet digital PCR (ddPCR). Covers reagents, thermal cycling, detection methods, curve analysis, and performance metrics.",
  "type": "object",
  "definitions": {
    "reagent": {
      "type": "object",
      "description": "Standardized structure for reagent quantities and provenance.",
      "properties": {
        "concentration": {
          "type": "number",
          "description": "Concentration in appropriate units (e.g., µM for primers, U/µL for enzymes, mM for dNTPs, ng/µL for DNA).",
          "minimum": 0
        },
        "volume": {
          "type": "number",
          "description": "Volume added to the reaction in µL.",
          "minimum": 0
        },
        "units": {
          "type": "string",
          "description": "Concentration units (e.g., µM, U/µL, mM, ng/µL, copies/µL)."
        },
        "manufacturer": { "type": "string" },
        "catalog_number": { "type": "string" },
        "lot_number": { "type": "string", "description": "Lot number for traceability." }
      },
      "required": ["concentration", "volume"]
    }
  },
  "properties": {
    "experiment_metadata": {
      "type": "object",
      "description": "Administrative and contextual metadata for the experiment.",
      "properties": {
        "experiment_id": { "type": "string" },
        "experiment_date": { "type": "string", "format": "date" },
        "operator": { "type": "string" },
        "lab_notebook_reference": { "type": "string" },
        "replicates": { "type": "integer", "minimum": 1 },
        "notes": { "type": "string" }
      },
      "required": ["experiment_id"]
    },
    "sample_preparation": {
      "type": "object",
      "description": "Sample origin, type, extraction, and quality.",
      "properties": {
        "sample_type": {
          "type": "string",
          "enum": ["tissue", "blood", "cell-free DNA", "circulating tumor cells", "FFPE", "RNA", "single-cell", "other"]
        },
        "sample_source": {
          "type": "string",
          "description": "Biological source of the sample (e.g., plasma, serum, urine, CSF, sputum, pleural effusion, ascites, stool, fresh tissue, exosomes)."
        },
        "extraction_method": {
          "type": "string",
          "description": "Nucleic acid extraction method (e.g., column-based, magnetic beads, phenol-chloroform, TRIzol, direct lysis)."
        },
        "sample_purity": { "type": "string" },
        "sample_degradation": {
          "type": "string",
          "enum": ["intact", "partially_degraded", "highly_degraded"]
        },
        "archival_sample": { "type": "boolean" },
        "reverse_transcription": {
          "type": "object",
          "description": "Parameters for RNA reverse transcription (RT-PCR).",
          "properties": {
            "performed": { "type": "boolean" },
            "enzyme": {
              "type": "string",
              "enum": ["M-MLV", "SuperScript III", "AMV", "other"]
            },
            "primer_type": {
              "type": "string",
              "enum": ["oligo(dT)", "random hexamers", "gene-specific primers", "other"]
            },
            "temperature": { "type": "number", "minimum": 0 },
            "time": { "type": "number", "minimum": 0, "description": "Duration in minutes." },
            "reagent_details": { "$ref": "#/definitions/reagent" }
          },
          "required": ["performed"]
        },
        "single_cell_pcr": {
          "type": "object",
          "description": "Parameters specific to single-cell PCR.",
          "properties": {
            "isolation_method": {
              "type": "string",
              "description": "Cell isolation method (e.g., micromanipulation, laser capture microdissection, flow cytometry, microfluidics)."
            },
            "amplification_bias": { "type": "string" },
            "preamplification": { "type": "boolean" },
            "preamplification_method": { "type": "string" }
          }
        }
      }
    },
    "reaction_components": {
      "type": "object",
      "description": "All reagents used in the PCR reaction.",
      "properties": {
        "template_dna": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["genomic DNA", "plasmid DNA", "cDNA", "synthetic DNA", "cell lysate", "single-cell DNA", "cfDNA", "ctDNA", "RNA", "other"]
            },
            "source": { "type": "string" },
            "initial_quantity": { "type": "number", "minimum": 0 },
            "purity": { "type": "string" },
            "degradation_status": { "type": "string" },
            "contamination": { "type": "string" },
            "reagent_details": { "$ref": "#/definitions/reagent" }
          },
          "required": ["type", "reagent_details"]
        },
        "primers": {
          "type": "object",
          "description": "Forward and reverse primers flanking the target region.",
          "properties": {
            "forward_primer": {
              "type": "object",
              "properties": {
                "sequence": { "type": "string", "pattern": "^[ATCGatcg]+$" },
                "length": { "type": "integer", "minimum": 1 },
                "tm": { "type": "number", "minimum": 0 },
                "gc_content": { "type": "number", "minimum": 0, "maximum": 100 },
                "modifications": { "type": "string" },
                "reagent_details": { "$ref": "#/definitions/reagent" }
              },
              "required": ["sequence", "length", "reagent_details"]
            },
            "reverse_primer": {
              "type": "object",
              "properties": {
                "sequence": { "type": "string", "pattern": "^[ATCGatcg]+$" },
                "length": { "type": "integer", "minimum": 1 },
                "tm": { "type": "number", "minimum": 0 },
                "gc_content": { "type": "number", "minimum": 0, "maximum": 100 },
                "modifications": { "type": "string" },
                "reagent_details": { "$ref": "#/definitions/reagent" }
              },
              "required": ["sequence", "length", "reagent_details"]
            },
            "nested_primers": {
              "type": "object",
              "description": "Optional nested primer pair for second-stage amplification.",
              "properties": {
                "forward_primer": {
                  "type": "object",
                  "properties": {
                    "sequence": { "type": "string", "pattern": "^[ATCGatcg]+$" },
                    "length": { "type": "integer", "minimum": 1 },
                    "tm": { "type": "number", "minimum": 0 },
                    "reagent_details": { "$ref": "#/definitions/reagent" }
                  },
                  "required": ["sequence", "length", "reagent_details"]
                },
                "reverse_primer": {
                  "type": "object",
                  "properties": {
                    "sequence": { "type": "string", "pattern": "^[ATCGatcg]+$" },
                    "length": { "type": "integer", "minimum": 1 },
                    "tm": { "type": "number", "minimum": 0 },
                    "reagent_details": { "$ref": "#/definitions/reagent" }
                  },
                  "required": ["sequence", "length", "reagent_details"]
                }
              }
            },
            "allele_specific_primers": {
              "type": "array",
              "description": "Allele-specific primers for SNP or mutation detection.",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "sequence": { "type": "string", "pattern": "^[ATCGatcg]+$" },
                  "length": { "type": "integer", "minimum": 1 },
                  "tm": { "type": "number", "minimum": 0 },
                  "target_allele": { "type": "string" },
                  "reagent_details": { "$ref": "#/definitions/reagent" }
                },
                "required": ["name", "sequence", "length", "target_allele", "reagent_details"]
              }
            },
            "competimer_primers": {
              "type": "array",
              "description": "Competitive primers used to modulate PCR efficiency.",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "sequence": { "type": "string", "pattern": "^[ATCGatcg]+$" },
                  "length": { "type": "integer", "minimum": 1 },
                  "modifications": { "type": "string", "description": "e.g., 3' amino modification to prevent extension." },
                  "percentage": {
                    "type": "number",
                    "description": "Percentage of competimer relative to total primer concentration.",
                    "minimum": 0, "maximum": 100
                  },
                  "reagent_details": { "$ref": "#/definitions/reagent" }
                },
                "required": ["name", "sequence", "length", "percentage", "reagent_details"]
              }
            }
          },
          "required": ["forward_primer", "reverse_primer"]
        },
        "allele_specific_oligonucleotides": {
          "type": "object",
          "description": "ASO probes for hybridization-based SNP detection.",
          "properties": {
            "probes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "sequence": { "type": "string", "pattern": "^[ATCGatcg]+$" },
                  "length": { "type": "integer", "minimum": 1 },
                  "target_allele": { "type": "string" },
                  "labeling": {
                    "type": "string",
                    "enum": ["radioactive", "biotin", "fluorescent", "none"]
                  },
                  "reagent_details": { "$ref": "#/definitions/reagent" }
                },
                "required": ["name", "sequence", "length", "target_allele", "reagent_details"]
              }
            },
            "hybridization_conditions": {
              "type": "object",
              "properties": {
                "temperature": { "type": "number", "minimum": 0 },
                "buffer": { "type": "string" },
                "wash_conditions": {
                  "type": "object",
                  "properties": {
                    "buffer": { "type": "string" },
                    "temperature": { "type": "number", "minimum": 0 },
                    "time": { "type": "number", "minimum": 0 }
                  },
                  "required": ["buffer", "temperature"]
                }
              },
              "required": ["temperature", "buffer"]
            }
          }
        },
        "fluorogenic_probes": {
          "type": "array",
          "description": "Fluorogenic probes for real-time PCR (TaqMan, molecular beacons, Scorpion primers, hybridization probes).",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "sequence": { "type": "string", "pattern": "^[ATCGatcg]+$" },
              "length": { "type": "integer", "minimum": 1 },
              "probe_type": {
                "type": "string",
                "enum": ["TaqMan", "molecular beacon", "Scorpion primer", "hybridization probe", "other"]
              },
              "labeling": {
                "type": "object",
                "properties": {
                  "reporter_dye": {
                    "type": "string",
                    "enum": ["FAM", "VIC", "TET", "HEX", "CY3", "CY5", "ROX", "other"]
                  },
                  "quencher_dye": {
                    "type": "string",
                    "enum": ["TAMRA", "BHQ1", "BHQ2", "MGB", "NFQ", "none", "other"]
                  }
                },
                "required": ["reporter_dye", "quencher_dye"]
              },
              "target_description": { "type": "string" },
              "reagent_details": { "$ref": "#/definitions/reagent" }
            },
            "required": ["name", "sequence", "length", "labeling", "reagent_details"]
          }
        },
        "dna_polymerase": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Taq", "Pfu", "Phusion", "Klenow fragment", "Tth", "reverse transcriptase", "other"]
            },
            "heat_stable": { "type": "boolean", "default": true },
            "nuclease_activity": {
              "type": "string",
              "enum": ["5'→3' exonuclease", "3'→5' exonuclease", "none"]
            },
            "reverse_transcriptase_activity": { "type": "boolean" },
            "inhibitor_tolerance": { "type": "string" },
            "reagent_details": { "$ref": "#/definitions/reagent" }
          },
          "required": ["type", "reagent_details"]
        },
        "dntps": {
          "type": "object",
          "properties": {
            "ratio": {
              "type": "object",
              "description": "Molar ratio of individual dNTPs (default 1:1:1:1).",
              "properties": {
                "dATP": { "type": "number", "minimum": 0 },
                "dTTP": { "type": "number", "minimum": 0 },
                "dCTP": { "type": "number", "minimum": 0 },
                "dGTP": { "type": "number", "minimum": 0 },
                "dUTP": { "type": "number", "minimum": 0 }
              }
            },
            "labeling": {
              "type": "string",
              "enum": ["radioactive", "fluorescent", "none"]
            },
            "reagent_details": { "$ref": "#/definitions/reagent" }
          },
          "required": ["reagent_details"]
        },
        "buffer_system": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "ph": { "type": "number", "minimum": 0, "maximum": 14 },
            "components": {
              "type": "object",
              "properties": {
                "mgcl2_concentration": { "type": "number", "minimum": 0 },
                "salt_concentration": { "type": "number", "minimum": 0 },
                "dmso_concentration": { "type": "number", "minimum": 0 },
                "betaine_concentration": { "type": "number", "minimum": 0 },
                "formamide_concentration": { "type": "number", "minimum": 0 },
                "dtt_concentration": { "type": "number", "minimum": 0 },
                "tween_20_concentration": { "type": "number", "minimum": 0 }
              }
            },
            "reagent_details": { "$ref": "#/definitions/reagent" }
          },
          "required": ["type", "ph", "reagent_details"]
        },
        "internal_controls": {
          "type": "object",
          "description": "Internal controls for normalization or validation (housekeeping genes, competitive templates, spike-ins).",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["housekeeping gene", "competitive template", "spike-in", "none"]
            },
            "target_description": { "type": "string" }
          }
        },
        "carryover_prevention": {
          "type": "object",
          "description": "Methods for preventing carryover contamination (UNG/dUTP).",
          "properties": {
            "method": {
              "type": "string",
              "enum": ["UNG treatment", "dUTP incorporation", "physical separation", "none"]
            },
            "ung_treatment": {
              "type": "object",
              "properties": {
                "temperature": { "type": "number", "minimum": 0 },
                "time": { "type": "number", "minimum": 0 },
                "reagent_details": { "$ref": "#/definitions/reagent" }
              },
              "required": ["temperature", "time", "reagent_details"]
            }
          }
        }
      },
      "required": ["template_dna", "primers", "dna_polymerase", "dntps", "buffer_system"]
    },
    "thermal_cycling_conditions": {
      "type": "object",
      "description": "Full thermal cycling protocol including initial denaturation, amplification cycles, final extension, and optional hold.",
      "properties": {
        "instrument": {
          "type": "string",
          "description": "Model of thermal cycler (e.g., ABI Prism 7700, GeneAmp PCR System 9600, LightCycler, QX200 Droplet Digital PCR System, CFX384)."
        },
        "initial_denaturation": {
          "type": "object",
          "properties": {
            "temperature": { "type": "number", "minimum": 0 },
            "time": { "type": "number", "minimum": 0 }
          },
          "required": ["temperature", "time"]
        },
        "reverse_transcription_step": {
          "type": "object",
          "description": "Optional reverse transcription step for RT-qPCR.",
          "properties": {
            "temperature": { "type": "number", "minimum": 0 },
            "time": { "type": "number", "minimum": 0 }
          }
        },
        "cycles": {
          "type": "array",
          "description": "Repeated amplification cycle steps.",
          "items": {
            "type": "object",
            "properties": {
              "denaturation": {
                "type": "object",
                "properties": {
                  "temperature": { "type": "number", "minimum": 0 },
                  "time": { "type": "number", "minimum": 0 }
                },
                "required": ["temperature", "time"]
              },
              "annealing": {
                "type": "object",
                "properties": {
                  "temperature": { "type": "number", "minimum": 0 },
                  "time": { "type": "number", "minimum": 0 }
                },
                "required": ["temperature", "time"]
              },
              "extension": {
                "type": "object",
                "properties": {
                  "temperature": { "type": "number", "minimum": 0 },
                  "time": { "type": "number", "minimum": 0 }
                },
                "required": ["temperature", "time"]
              },
              "fluorescence_acquisition": {
                "type": "object",
                "description": "Real-time fluorescence monitoring parameters.",
                "properties": {
                  "temperature": { "type": "number", "minimum": 0 },
                  "time": { "type": "number", "minimum": 0 },
                  "acquisition_mode": {
                    "type": "string",
                    "enum": ["single", "continuous", "none"]
                  }
                }
              }
            },
            "required": ["denaturation", "annealing", "extension"]
          }
        },
        "final_extension": {
          "type": "object",
          "properties": {
            "temperature": { "type": "number", "minimum": 0 },
            "time": { "type": "number", "minimum": 0 }
          },
          "required": ["temperature", "time"]
        },
        "number_of_cycles": {
          "type": "integer",
          "description": "Total amplification cycles (e.g., 25 for PCR-ASO, 40 for qPCR).",
          "minimum": 1
        },
        "hold": {
          "type": "object",
          "description": "Optional post-cycling hold step.",
          "properties": {
            "temperature": { "type": "number", "minimum": 0 },
            "time": { "type": "number", "minimum": 0 }
          }
        },
        "ramp_rate": {
          "type": "number",
          "description": "Rate of temperature change between steps in °C/second."
        },
        "melting_curve_analysis": {
          "type": "object",
          "description": "Post-amplification melting curve parameters.",
          "properties": {
            "start_temperature": { "type": "number", "minimum": 0 },
            "end_temperature": { "type": "number", "minimum": 0 },
            "increment": { "type": "number", "minimum": 0 },
            "hold_time": { "type": "number", "minimum": 0 }
          },
          "required": ["start_temperature", "end_temperature", "increment"]
        },
        "ddpcr_specific": {
          "type": "object",
          "description": "Parameters specific to droplet digital PCR.",
          "properties": {
            "droplet_generation": {
              "type": "object",
              "properties": {
                "oil_type": { "type": "string" },
                "droplet_volume": { "type": "number", "minimum": 0 },
                "number_of_droplets": { "type": "integer", "minimum": 1 }
              },
              "required": ["oil_type", "droplet_volume", "number_of_droplets"]
            },
            "droplet_reading": {
              "type": "object",
              "properties": {
                "instrument": { "type": "string" },
                "threshold_setting": {
                  "type": "string",
                  "enum": ["automatic", "manual", "algorithmic"]
                },
                "rain_droplet_handling": {
                  "type": "string",
                  "enum": ["exclude", "include", "classify-separately"]
                },
                "poisson_correction": { "type": "boolean", "default": true },
                "limit_of_blank": { "type": "number" },
                "limit_of_detection": { "type": "number" }
              },
              "required": ["instrument"]
            }
          }
        }
      },
      "required": ["initial_denaturation", "cycles", "number_of_cycles", "final_extension"]
    },
    "amplicon": {
      "type": "object",
      "description": "Properties of the amplified DNA fragment.",
      "properties": {
        "length": { "type": "integer", "minimum": 1 },
        "sequence": { "type": "string", "pattern": "^[ATCGatcg]+$" },
        "gc_content": { "type": "number", "minimum": 0, "maximum": 100 },
        "target_description": { "type": "string" },
        "restriction_sites": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "enzyme": { "type": "string" },
              "sequence": { "type": "string", "pattern": "^[ATCGatcg]+$" },
              "position": { "type": "integer", "minimum": 1 },
              "polymorphic": { "type": "boolean" }
            },
            "required": ["enzyme", "sequence"]
          }
        }
      },
      "required": ["length"]
    },
    "detection_method": {
      "type": "object",
      "description": "Method for visualizing or quantifying PCR products.",
      "properties": {
        "method": {
          "type": "string",
          "enum": ["gel electrophoresis", "autoradiography", "dot blot", "qPCR fluorescence", "sequencing", "radioactive labeling", "oligomer restriction", "real-time PCR", "melting curve analysis", "ddPCR", "other"]
        },
        "details": {
          "type": "object",
          "properties": {
            "gel_electrophoresis": {
              "type": "object",
              "properties": {
                "gel_type": {
                  "type": "string",
                  "enum": ["agarose", "polyacrylamide", "NuSieve agarose", "alkaline agarose", "other"]
                },
                "gel_concentration": { "type": "number", "minimum": 0 },
                "dye": { "type": "string" },
                "buffer": { "type": "string" },
                "voltage": { "type": "number", "minimum": 0 },
                "run_time": { "type": "number", "minimum": 0 }
              }
            },
            "quantitative_analysis": {
              "type": "object",
              "description": "Real-time PCR quantitative analysis parameters.",
              "properties": {
                "instrument": { "type": "string" },
                "baseline_correction": {
                  "type": "object",
                  "properties": {
                    "method": {
                      "type": "string",
                      "enum": ["automatic", "manual", "user-defined"]
                    },
                    "cycle_range": { "type": "string" }
                  },
                  "required": ["method"]
                },
                "threshold": { "type": "number", "minimum": 0 },
                "threshold_method": {
                  "type": "string",
                  "enum": ["automatic", "manual", "dynamic"]
                },
                "curve_analysis_method": {
                  "type": "string",
                  "description": "Algorithm used for qPCR curve analysis.",
                  "enum": ["Standard-Cq", "LinRegPCR", "FPLM", "DART", "5PSM", "MAK2", "FPK-PCR", "LRE-Emax", "LRE-E100", "Cy0", "PCR-Miner"]
                },
                "efficiency_model": {
                  "type": "string",
                  "enum": ["constant", "continuously decreasing"],
                  "description": "Assumption about PCR efficiency across cycles."
                },
                "cq_value": {
                  "type": "number",
                  "description": "Quantification cycle (Cq/Ct): cycle at which fluorescence exceeds threshold.",
                  "minimum": 0
                },
                "cy0_value": {
                  "type": "number",
                  "description": "Cy0: intersection of the abscissa and the tangent at the inflection point of the Richards curve."
                },
                "f0_value": {
                  "type": "number",
                  "description": "Initial fluorescence (F0) associated with target quantity, calculated as Fq/E^Cq."
                },
                "fq_threshold": {
                  "type": "number",
                  "description": "Fluorescence threshold used to determine Cq."
                },
                "fb_baseline": {
                  "type": "number",
                  "description": "Baseline fluorescence independent of amplification."
                },
                "arn": {
                  "type": "number",
                  "description": "Normalized reporter fluorescence (ARn = Rn+ − Rn−)."
                },
                "data_analysis": {
                  "type": "object",
                  "properties": {
                    "method": {
                      "type": "string",
                      "enum": ["Cq", "ΔΔCq", "standard curve", "sigmoidal curve fitting", "efficiency-based", "other"]
                    },
                    "normalization": { "type": "string" },
                    "efficiency_calculation": { "type": "string" },
                    "dynamic_range": { "type": "string" },
                    "limit_of_detection": { "type": "number" },
                    "limit_of_blank": { "type": "number" }
                  },
                  "required": ["method"]
                },
                "performance_metrics": {
                  "type": "object",
                  "description": "Performance metrics for evaluating qPCR curve analysis methods.",
                  "properties": {
                    "bias": {
                      "type": "number",
                      "description": "Ratio of mean F0 for highest vs. lowest input (expected = input fold difference, e.g., 10,000 for 4 log10 dilution series)."
                    },
                    "precision": {
                      "type": "number",
                      "description": "Within-triplicate variance of observed F0 values."
                    },
                    "resolution": {
                      "type": "number",
                      "description": "Smallest detectable fold-difference at 5% significance level."
                    },
                    "linearity": {
                      "type": "number",
                      "description": "Variance due to deviation from the regression line of log(input) vs. log(F0)."
                    },
                    "amplification_efficiency": {
                      "type": "number",
                      "description": "Amplification efficiency per cycle as fold increase (1–2).",
                      "minimum": 0,
                      "maximum": 2
                    },
                    "dynamic_range": { "type": "string" }
                  }
                },
                "ddpcr_analysis": {
                  "type": "object",
                  "properties": {
                    "absolute_quantification": { "type": "boolean" },
                    "poisson_correction": { "type": "boolean" },
                    "droplet_classification": {
                      "type": "object",
                      "properties": {
                        "positive_droplets": { "type": "integer", "minimum": 0 },
                        "negative_droplets": { "type": "integer", "minimum": 0 },
                        "total_droplets": { "type": "integer", "minimum": 1 },
                        "threshold_method": { "type": "string" }
                      },
                      "required": ["positive_droplets", "negative_droplets", "total_droplets"]
                    },
                    "mutation_detection": {
                      "type": "object",
                      "properties": {
                        "mutation_type": { "type": "string" },
                        "allele_frequency": { "type": "number", "minimum": 0, "maximum": 1 },
                        "limit_of_detection": { "type": "number" }
                      }
                    }
                  }
                }
              }
            },
            "dot_blot": {
              "type": "object",
              "properties": {
                "membrane_type": { "type": "string" },
                "denaturation_method": { "type": "string" },
                "fixation_method": { "type": "string" },
                "probe_label": { "type": "string" }
              }
            },
            "autoradiography": {
              "type": "object",
              "properties": {
                "exposure_time": { "type": "number", "minimum": 0 },
                "temperature": { "type": "number" },
                "intensification_screen": { "type": "boolean" }
              }
            }
          }
        }
      },
      "required": ["method"]
    },
    "restriction_analysis": {
      "type": "object",
      "description": "Post-PCR restriction enzyme digestion for allele discrimination (e.g., PCR-OR).",
      "properties": {
        "enzymes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "digestion_conditions": {
          "type": "object",
          "properties": {
            "temperature": { "type": "number", "minimum": 0 },
            "time": { "type": "number", "minimum": 0 },
            "buffer": { "type": "string" }
          },
          "required": ["temperature", "time"]
        },
        "sequential_digestion": { "type": "boolean" }
      }
    },
    "efficiency_metrics": {
      "type": "object",
      "description": "Amplification efficiency and yield metrics.",
      "properties": {
        "amplification_efficiency": {
          "type": "number",
          "description": "Efficiency per cycle as fold increase (1–2).",
          "minimum": 0,
          "maximum": 2
        },
        "total_amplification": { "type": "number", "minimum": 0 },
        "cq_value": { "type": "number" },
        "dynamic_range": { "type": "string" },
        "calculation_method": { "type": "string" },
        "efficiency_model": {
          "type": "string",
          "enum": ["constant", "continuously decreasing"]
        }
      }
    },
    "reaction_volume": {
      "type": "number",
      "description": "Total PCR reaction volume in µL.",
      "minimum": 0
    },
    "experimental_parameters": {
      "type": "object",
      "properties": {
        "specificity": { "type": "string" },
        "mutagenesis": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "sequence_added": { "type": "string", "pattern": "^[ATCGatcg]+$" },
            "position": { "type": "integer", "minimum": 1 }
          }
        },
        "notes": { "type": "string" },
        "automation": { "type": "boolean" },
        "contamination_control": { "type": "string" },
        "inhibition_control": { "type": "string" }
      }
    },
    "controls": {
      "type": "object",
      "description": "Experimental controls.",
      "properties": {
        "negative_control": { "type": "boolean" },
        "wild_type_control": { "type": "boolean" },
        "no_template_control": { "type": "boolean" },
        "no_reverse_transcriptase_control": { "type": "boolean" },
        "positive_control": { "type": "boolean" }
      }
    }
  },
  "required": [
    "experiment_metadata",
    "reaction_components",
    "thermal_cycling_conditions",
    "amplicon",
    "detection_method",
    "reaction_volume"
  ]
}
